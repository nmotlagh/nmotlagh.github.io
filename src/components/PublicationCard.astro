---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'publications'>;
  artifacts?: CollectionEntry<'artifacts'>[];
}

const { entry, artifacts = [] }: Props = Astro.props;
const { data, slug } = entry;
const detailHref = `${import.meta.env.BASE_URL}publications/${slug}/`;

const badges: { label: string; href?: string }[] = [
  { label: 'Paper', href: data.pdf ?? data.external ?? detailHref },
  { label: 'arXiv', href: data.arxiv },
  { label: 'Code', href: data.code },
  { label: 'Data', href: data.data },
  { label: 'Slides', href: data.slides },
];
const isExternalHref = (href: string) => /^https?:\/\//.test(href);
---

<article class="publication-card surface">
  <div class="publication-card__meta">
    <p class="publication-card__eyebrow">{data.venue} / {data.year}</p>
    {data.award && <span class="publication-card__award">{data.award}</span>}
  </div>

  <h3 class="publication-card__title">
    <a href={detailHref} data-pretext-balance data-pretext-source={data.title}>
      {data.title}
    </a>
  </h3>
  <p class="publication-card__authors">{data.authors.join(', ')}</p>
  <p class="publication-card__tldr">{data.tldr}</p>

  {Array.isArray(data.tags) && data.tags.length > 0 && (
    <ul class="publication-card__tags" role="list">
      {data.tags.map((tag) => (
        <li class="tag">{tag}</li>
      ))}
    </ul>
  )}

  {data.highlights && data.highlights.length > 0 && (
    <ul class="publication-card__highlights">
      {data.highlights.slice(0, 2).map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  )}

  {badges.some((badge) => Boolean(badge.href)) && (
    <div class="publication-card__links">
      {badges.map(
        (badge) =>
          badge.href && (
            <a
              class="badge badge--link"
              aria-label={`${badge.label} for ${data.title}`}
              href={badge.href}
              target={isExternalHref(badge.href) ? '_blank' : undefined}
              rel={isExternalHref(badge.href) ? 'noopener noreferrer' : undefined}
            >
              {badge.label}
            </a>
          ),
      )}
    </div>
  )}

  {artifacts.length > 0 && (
    <div class="publication-card__artifact-row">
      <span>Artifacts</span>
      <p>{artifacts.map((artifact) => artifact.data.name).join(' · ')}</p>
    </div>
  )}
</article>

<style>
  .publication-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.25rem;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .publication-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .publication-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.75rem;
    align-items: center;
  }

  .publication-card__eyebrow {
    font: 600 0.72rem/1.2 var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin: 0;
  }

  .publication-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 1.8vw, 1.95rem);
    font-weight: 650;
    line-height: 1.05;
  }

  .publication-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .publication-card__title a:hover {
    color: var(--color-accent);
  }

  .publication-card__authors {
    font: 700 0.76rem/1.6 var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-soft);
    margin: 0;
  }

  .publication-card__tldr {
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.75;
  }

  .publication-card__award {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    background: var(--color-secondary-soft);
    color: var(--color-text);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--color-secondary) 42%, var(--color-border));
  }

  .publication-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .publication-card__highlights {
    margin: 0;
    padding-left: 1.05rem;
    color: var(--color-text-muted);
    display: grid;
    gap: 0.45rem;
  }

  .publication-card__highlights li::marker {
    color: var(--color-accent);
  }

  .publication-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .publication-card__artifact-row {
    padding-top: 0.95rem;
    border-top: 1px solid var(--color-border);
  }

  .publication-card__artifact-row span {
    display: block;
    margin-bottom: 0.4rem;
    color: var(--color-text-soft);
    font: 600 0.72rem/1.2 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .publication-card__artifact-row p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .publication-card {
      padding: 1.05rem;
    }

    .publication-card__title {
      font-size: clamp(1.3rem, 7vw, 1.55rem);
    }
  }
</style>

---
interface RoleItem {
  role: string;
  location?: string;
  timeframe: string;
}

interface Props {
  facts: string[];
  roles: RoleItem[];
  resumeHref: string;
  emailHref: string;
  linkedInHref: string;
  githubHref: string;
}

const { facts, roles, resumeHref, emailHref, linkedInHref, githubHref }: Props = Astro.props;
---

<section class="contact-rail surface surface--raised">
  <div class="contact-rail__intro">
    <p class="eyebrow">Work with me</p>
    <h2>Available fall 2026 — open to research scientist and applied ML engineering roles.</h2>
    <p>
      Interested in teams where uncertainty, calibration, and evaluation
      quality are first-class concerns. Happy to talk about abstention for
      LLM agents, selective prediction in vision, or adaptive retrieval.
    </p>

    <div class="contact-rail__actions">
      <a class="button" href={emailHref}>Email me</a>
      <a class="button button--ghost" href={resumeHref} target="_blank" rel="noopener noreferrer">
        View resume
      </a>
    </div>
  </div>

  <div class="contact-rail__details">
    <div class="contact-rail__panel">
      <p class="eyebrow">At a glance</p>
      <ul>
        {facts.map((fact) => (
          <li>{fact}</li>
        ))}
      </ul>

      <div class="contact-rail__links">
        <a href={linkedInHref} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href={githubHref} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={emailHref}>Email</a>
      </div>
    </div>

    <div class="contact-rail__panel">
      <p class="eyebrow">Recent roles</p>
      <ol class="contact-rail__roles">
        {roles.map((role) => (
          <li>
            <p>{role.role}</p>
            <span>{role.location ? `${role.location} / ${role.timeframe}` : role.timeframe}</span>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .contact-rail {
    display: grid;
    gap: 1.5rem;
    padding: clamp(1.4rem, 3vw, 2.4rem);
  }

  @media (min-width: 960px) {
    .contact-rail {
      grid-template-columns: minmax(0, 1.15fr) minmax(21rem, 0.95fr);
      align-items: start;
    }
  }

  .contact-rail__intro h2 {
    margin: 0;
    max-width: 12ch;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 4rem);
    font-weight: 620;
    line-height: 0.96;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .contact-rail__intro p:last-of-type {
    margin: 1rem 0 0;
    max-width: 40rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .contact-rail__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .contact-rail__details {
    display: grid;
    gap: 1rem;
  }

  .contact-rail__panel {
    padding: 1rem 1.05rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--color-panel) 88%, transparent);
  }

  .contact-rail__panel ul,
  .contact-rail__roles {
    margin: 0.8rem 0 0;
    padding-left: 1.05rem;
    color: var(--color-text-muted);
    display: grid;
    gap: 0.6rem;
  }

  .contact-rail__panel li::marker {
    color: var(--color-accent);
  }

  .contact-rail__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .contact-rail__links a {
    color: var(--color-text);
    font-weight: 500;
  }

  .contact-rail__links a:hover {
    color: var(--color-accent);
  }

  .contact-rail__roles {
    list-style: decimal-leading-zero;
  }

  .contact-rail__roles p {
    margin: 0;
    color: var(--color-text);
    font-weight: 600;
  }

  .contact-rail__roles span {
    display: block;
    margin-top: 0.15rem;
    color: var(--color-text-soft);
    font-size: 0.9rem;
    line-height: 1.55;
  }
</style>

---
import { Image } from "astro:assets";
import headshot from "../../assets/headshot.jpg";

interface ActionLink {
  label: string;
  href: string;
  variant?: "primary" | "ghost";
  external?: boolean;
}

interface StatItem {
  label: string;
  value: string;
}

interface AvailabilityBadge {
  label: string;
  detail: string;
}

interface Props {
  eyebrow: string;
  availability?: AvailabilityBadge;
  title: string;
  ledeHtml: string;
  supporting: string;
  status: string;
  actions: ActionLink[];
  stats: StatItem[];
  scholarHref: string;
  githubHref: string;
  linkedInHref: string;
  emailHref: string;
}

const {
  eyebrow,
  availability,
  title,
  ledeHtml,
  supporting,
  status,
  actions,
  stats,
  scholarHref,
  githubHref,
  linkedInHref,
  emailHref,
}: Props = Astro.props;

const profileLinks = [
  { label: "Scholar", href: scholarHref },
  { label: "GitHub", href: githubHref },
  { label: "LinkedIn", href: linkedInHref },
  { label: "Email", href: emailHref },
];
---

<section class="editorial-hero" aria-labelledby="intro-title">
  <div class="editorial-hero__copy">
    <p class="editorial-hero__eyebrow">{eyebrow}</p>
    <h1 id="intro-title" class="editorial-hero__title">{title}</h1>
    <p class="editorial-hero__lede" set:html={ledeHtml} />

    <ul class="decision-strip editorial-hero__strip" aria-label="Answer, abstain, refine">
      <li data-tone="answer">Answer</li>
      <li data-tone="abstain">Abstain</li>
      <li data-tone="refine">Refine</li>
    </ul>

    <p class="editorial-hero__supporting" set:html={supporting} />

    <p class="editorial-hero__status">
      <span class="editorial-hero__status-label">Now</span>
      <span>{status}</span>
    </p>

    <div class="editorial-hero__actions">
      {actions.map((action) => (
        <a
          class:list={["button", action.variant === "ghost" && "button--ghost"]}
          href={action.href}
          target={action.external ? "_blank" : undefined}
          rel={action.external ? "noopener noreferrer" : undefined}
        >
          {action.label}
        </a>
      ))}
    </div>
  </div>

  <aside class="editorial-hero__visual" aria-label="Profile and availability">
    <figure class="editorial-hero__portrait">
      <Image
        src={headshot}
        alt="Nick Kashani Motlagh"
        width={720}
        height={960}
        sizes="(max-width: 960px) 100vw, 19rem"
        loading="eager"
      />
      <span class="editorial-hero__tick editorial-hero__tick--tl" aria-hidden="true"></span>
      <span class="editorial-hero__tick editorial-hero__tick--br" aria-hidden="true"></span>
    </figure>

    {availability && (
      <p class="editorial-hero__availability">
        <span class="editorial-hero__availability-dot" aria-hidden="true"></span>
        <span>
          <strong>{availability.label}</strong>
          <span>{availability.detail}</span>
        </span>
      </p>
    )}

    <nav class="editorial-hero__links" aria-label="Profile links">
      <ul>
        {profileLinks.map((link) => (
          <li>
            <a
              href={link.href}
              target={link.href.startsWith("mailto:") ? undefined : "_blank"}
              rel={link.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>

  <dl class="editorial-hero__stats">
    {stats.map((stat) => (
      <div class="editorial-hero__stat">
        <dt>{stat.label}</dt>
        <dd>{stat.value}</dd>
      </div>
    ))}
  </dl>
</section>

<style>
  .editorial-hero {
    position: relative;
    display: grid;
    gap: clamp(1.6rem, 4vw, 3.5rem);
    align-items: end;
    max-width: 100%;
    padding-top: clamp(1.5rem, 4vw, 3.5rem);
    overflow-x: clip;
  }

  @media (min-width: 960px) {
    .editorial-hero {
      grid-template-columns: minmax(0, 1.45fr) minmax(19rem, 0.55fr);
    }
  }

  .editorial-hero__copy {
    position: relative;
    min-width: 0;
    max-width: 100%;
    overflow-x: clip;
  }

  .editorial-hero__eyebrow {
    margin: 0 0 clamp(1.1rem, 2.5vw, 1.8rem);
    color: var(--color-text-muted);
    font: 600 0.72rem/1.5 var(--font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .editorial-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 0.5em;
    height: 0.5em;
    margin-right: 0.6em;
    background: var(--color-secondary);
    vertical-align: 6%;
  }

  .editorial-hero__title {
    margin: 0;
    max-width: 12ch;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 8.6vw, 7.6rem);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 0.9;
  }

  .editorial-hero__lede {
    margin: clamp(1.2rem, 2.6vw, 1.9rem) 0 0;
    max-width: 24ch;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 1.1rem + 2.3vw, 3rem);
    font-weight: 400;
    line-height: 1.08;
    overflow-wrap: break-word;
  }

  .editorial-hero__lede :global(em) {
    color: var(--color-accent);
  }

  .editorial-hero__strip {
    margin-top: clamp(1.2rem, 2.4vw, 1.7rem);
  }

  .editorial-hero__supporting {
    margin: clamp(1.2rem, 2.4vw, 1.7rem) 0 0;
    max-width: 46rem;
    color: var(--color-text-muted);
    font-size: 1.04rem;
    line-height: 1.75;
    overflow-wrap: break-word;
  }

  .editorial-hero__supporting :global(em) {
    font-style: italic;
    color: var(--color-text);
  }

  .editorial-hero__status {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: start;
    gap: 0.7rem;
    max-width: 45rem;
    margin: 1.45rem 0 0;
    padding: 0.85rem 0;
    border-block: var(--hairline);
    color: var(--color-text-muted);
    font-size: 0.94rem;
    line-height: 1.6;
  }

  .editorial-hero__status-label {
    display: inline-flex;
    align-items: center;
    margin-top: 0.12rem;
    padding: 0.16rem 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 36%, var(--color-border));
    border-radius: var(--radius-sm);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font: 600 0.68rem/1.4 var(--font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .editorial-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .editorial-hero__visual {
    position: relative;
    display: grid;
    gap: 0.9rem;
    align-content: end;
    min-width: 0;
  }

  .editorial-hero__portrait {
    position: relative;
    margin: 0;
    border: var(--hairline-strong);
    background: var(--color-surface-alt);
  }

  .editorial-hero__portrait :global(img) {
    width: 100%;
    aspect-ratio: 0.86;
    height: auto;
    object-fit: cover;
    object-position: center 20%;
    filter: saturate(0.92);
  }

  .editorial-hero__tick {
    position: absolute;
    width: 1rem;
    height: 1rem;
    pointer-events: none;
  }

  .editorial-hero__tick--tl {
    top: -0.5rem;
    left: -0.5rem;
    border-top: 2px solid var(--color-accent);
    border-left: 2px solid var(--color-accent);
  }

  .editorial-hero__tick--br {
    bottom: -0.5rem;
    right: -0.5rem;
    border-bottom: 2px solid var(--color-secondary);
    border-right: 2px solid var(--color-secondary);
  }

  .editorial-hero__availability {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem;
    margin: 0;
    padding: 0.78rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--color-positive) 40%, var(--color-border));
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-positive-soft) 64%, transparent);
    color: var(--color-text-muted);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .editorial-hero__availability strong {
    display: block;
    color: var(--color-text);
    font: 700 0.72rem/1.3 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .editorial-hero__availability span span {
    display: block;
    margin-top: 0.22rem;
  }

  .editorial-hero__availability > span:last-child {
    min-width: 0;
    overflow-wrap: break-word;
  }

  .editorial-hero__availability-dot {
    width: 0.55rem;
    height: 0.55rem;
    margin-top: 0.32rem;
    border-radius: 50%;
    background: var(--color-positive);
    box-shadow: 0 0 0 0.2rem color-mix(in srgb, var(--color-positive) 22%, transparent);
  }

  .editorial-hero__links ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.42rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .editorial-hero__links a {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border: var(--hairline);
    border-radius: var(--radius-sm);
    background: var(--color-panel);
    color: var(--color-text);
    font: 600 0.74rem/1.2 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .editorial-hero__links a:hover,
  .editorial-hero__links a:focus-visible {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .editorial-hero__stats {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    margin: clamp(0.6rem, 2vw, 1.4rem) 0 0;
    padding: 0;
    border: var(--hairline);
    border-radius: var(--radius-md);
    background: var(--color-panel);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .editorial-hero__stat {
    position: relative;
    min-width: 0;
    padding: 1rem 1.05rem 0.95rem;
    border-right: var(--hairline);
  }

  .editorial-hero__stat::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.05rem;
    width: 1px;
    height: 0.45rem;
    background: var(--color-border-strong);
  }

  .editorial-hero__stat:nth-child(4n) {
    border-right: none;
  }

  .editorial-hero__stat dt {
    margin: 0;
    color: var(--color-text-soft);
    font: 600 0.66rem/1.3 var(--font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .editorial-hero__stat dd {
    margin: 0.4rem 0 0;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.05rem + 0.6vw, 1.6rem);
    line-height: 1.05;
  }

  @media (max-width: 959px) {
    .editorial-hero__visual {
      grid-template-columns: minmax(0, 0.7fr) minmax(0, 1fr);
      align-items: center;
    }

    .editorial-hero__links {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 720px) {
    .editorial-hero__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .editorial-hero__stat {
      border-bottom: var(--hairline);
    }

    .editorial-hero__stat:nth-child(2n) {
      border-right: none;
    }

    .editorial-hero__stat:nth-last-child(-n + 2) {
      border-bottom: none;
    }
  }

  @media (max-width: 640px) {
    .editorial-hero__title {
      font-size: clamp(2.9rem, 13.5vw, 3.6rem);
    }

    .editorial-hero__lede {
      max-width: 100%;
      font-size: clamp(1.45rem, 6.6vw, 1.8rem);
    }

    .editorial-hero__eyebrow {
      font-size: 0.64rem;
      letter-spacing: 0.1em;
    }

    .editorial-hero__visual {
      grid-template-columns: 1fr;
    }

    .editorial-hero__portrait :global(img) {
      aspect-ratio: 1.15;
    }
  }
</style>

---
import type { ImageMetadata } from 'astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/theme.css';
import '../styles/editorial.css';
import headshot from '../assets/headshot.jpg';

const siteName = 'Nick Kashani Motlagh';
const defaultDescription =
  'PhD candidate at The Ohio State University building uncertainty-aware ML systems that know when to stop guessing.';

interface LayoutProps {
  title?: string;
  description?: string;
  ogImage?: string | ImageMetadata;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  showSidebar?: boolean;
}

const { title, description = defaultDescription, ogImage, structuredData }: LayoutProps = Astro.props;

const pageTitle = title ? `${title} · ${siteName}` : siteName;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const homeHref = import.meta.env.BASE_URL;
const resumeHref = `${homeHref}resume.pdf`;
const scholarHref = 'https://scholar.google.com/citations?user=srZXFMcAAAAJ&hl=en';
const githubHref = 'https://github.com/nmotlagh';
const linkedInHref = 'https://www.linkedin.com/in/nicholas-kashani-motlagh';
const emailHref = 'mailto:kashanimotlagh.1@osu.edu';
const faviconHref = `${homeHref}favicon.svg`;
const rssHref = `${homeHref}rss.xml`;
const structured = Array.isArray(structuredData)
  ? structuredData.filter(Boolean)
  : structuredData
    ? [structuredData]
    : [];
const resolvedOgImage = ogImage ?? headshot;
const ogImageUrl =
  typeof resolvedOgImage === 'string'
    ? resolvedOgImage
    : Astro.site
      ? new URL(resolvedOgImage.src, Astro.site).href
      : resolvedOgImage.src;

const normalizePath = (path: string) => (path.endsWith('/') ? path : `${path}/`);
const currentPath = normalizePath(Astro.url.pathname);
const isActivePath = (href: string) => {
  const targetPath = normalizePath(new URL(href, Astro.url).pathname);
  if (targetPath === normalizePath(homeHref)) {
    return currentPath === targetPath;
  }
  return currentPath.startsWith(targetPath);
};

const navLinks = [
  { label: 'Home', href: homeHref },
  { label: 'Publications', href: `${homeHref}publications/` },
  { label: 'Artifacts', href: `${homeHref}artifacts/` },
  { label: 'Blog', href: `${homeHref}blog/` },
  { label: 'News', href: `${homeHref}news/` },
].map((link) => ({ ...link, active: isActivePath(link.href) }));
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f4efe6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#11100d" media="(prefers-color-scheme: dark)" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Inter:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,500;6..72,600;6..72,700&display=swap"
    />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:site" content="@NickMotlagh" />
    <meta name="twitter:creator" content="@NickMotlagh" />
    <link rel="alternate" type="application/rss+xml" title="News · Nick Kashani Motlagh" href={rssHref} />
    <script defer data-domain="nmotlagh.github.io" src="https://plausible.io/js/script.js"></script>
    <script is:inline>
      (function () {
        const storageKey = 'theme-preference';
        const doc = document.documentElement;
        const media = window.matchMedia('(prefers-color-scheme: dark)');

        const getStored = () => {
          try {
            return localStorage.getItem(storageKey);
          } catch (_) {
            return null;
          }
        };

        const setStored = (value) => {
          try {
            localStorage.setItem(storageKey, value);
          } catch (_) {
            // Ignore storage failures.
          }
        };

        const applyTheme = (value) => {
          doc.dataset.theme = value === 'dark' ? 'dark' : 'light';
        };

        const init = () => {
          const stored = getStored();
          applyTheme(stored ? stored : media.matches ? 'dark' : 'light');
        };

        init();

        media.addEventListener('change', (event) => {
          if (!getStored()) {
            applyTheme(event.matches ? 'dark' : 'light');
          }
        });

        window.__setTheme = (preference) => {
          setStored(preference);
          applyTheme(preference);
          return preference;
        };

        window.__clearThemePreference = () => {
          try {
            localStorage.removeItem(storageKey);
          } catch (_) {
            //
          }
          applyTheme(media.matches ? 'dark' : 'light');
        };
      })();
    </script>
    {structured.map((entry) => (
      <script type="application/ld+json" is:inline>{JSON.stringify(entry)}</script>
    ))}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#page-content">Skip to content</a>

    <div class="site-chrome">
      <header class="site-header">
        <div class="site-shell site-header__bar">
          <a class="site-header__brand" href={homeHref}>
            <span class="site-header__title">{siteName}</span>
          </a>

          <div class="site-header__nav" aria-label="Primary navigation">
            {navLinks.map((link) => (
              <a
                class="site-header__nav-link"
                href={link.href}
                data-active={link.active ? 'true' : 'false'}
                data-astro-prefetch
              >
                {link.label}
              </a>
            ))}
            <a
              class="site-header__nav-link--cta"
              href={resumeHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              Resume
            </a>
            <ThemeToggle />
          </div>
        </div>
      </header>

      <main id="page-content" class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-shell site-footer__grid">
          <div>
            <h2 class="site-footer__title">Nick Kashani Motlagh</h2>
            <p class="site-footer__copy">
              PhD candidate at Ohio State. Columbus, Ohio.
              Research on selective prediction, abstention, and adaptive question answering.
            </p>
          </div>

          <div class="site-footer__links">
            <a href={emailHref}>Email</a>
            <a href={scholarHref} target="_blank" rel="noopener noreferrer">Scholar</a>
            <a href={githubHref} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={linkedInHref} target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href={resumeHref} target="_blank" rel="noopener noreferrer">Resume</a>
          </div>
        </div>
      </footer>
    </div>

    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof window.plausible !== 'function') return;
        document.querySelectorAll('[data-analytics-event]').forEach((element) => {
          element.addEventListener('click', () => {
            window.plausible(element.getAttribute('data-analytics-event'));
          });
        });
      });
    </script>
  </body>
</html>

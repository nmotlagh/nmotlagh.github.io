---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import EditorialHero from "../components/editorial/EditorialHero.astro";
import DissertationPillars from "../components/editorial/DissertationPillars.astro";
import FeatureSlab from "../components/editorial/FeatureSlab.astro";
import ResearchArc from "../components/editorial/ResearchArc.astro";
import DispatchList from "../components/editorial/DispatchList.astro";
import ContactRail from "../components/editorial/ContactRail.astro";
import { homeEditorial, researchArc, dissertationPillars } from "../data/editorial";
import { parseDateValue } from "../utils/dates";
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";
import headshot from "../assets/headshot.jpg";

const about = await getEntry("pages", "about");
const experience = await getEntry("pages", "experience");
const aboutRendered = about ? await about.render() : undefined;
const experienceItems = experience?.data.items ?? [];

const publicationEntries = await getCollection("publications", ({ data }) => !data.draft);
const publications = publicationEntries.sort((a, b) => b.data.year - a.data.year);
const isCurrentManuscript = (entry: CollectionEntry<"publications">) =>
  entry.data.venue.toLowerCase().includes("preparation");
const peerReviewedPublications = publications.filter((entry) => !isCurrentManuscript(entry));
const publicationLookup = new Map(publications.map((entry) => [entry.slug, entry]));

const artifactEntries = await getCollection("artifacts");
const artifactMap = new Map<string, CollectionEntry<"artifacts">[]>();
artifactEntries.forEach((artifact) => {
  artifact.data.tiesTo.forEach((slug) => {
    if (!artifactMap.has(slug)) {
      artifactMap.set(slug, []);
    }
    artifactMap.get(slug)?.push(artifact);
  });
});
const artifactLookup = new Map(artifactEntries.map((entry) => [entry.id, entry]));

const featuredPublications = homeEditorial.featuredPublicationSlugs
  .map((slug) => publicationLookup.get(slug))
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));

const featuredArtifacts = homeEditorial.featuredArtifactIds
  .map((id) => artifactLookup.get(id))
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));

const newsItems = (await getCollection("news", ({ data }) => !data.draft))
  .sort((a, b) => parseDateValue(b.data.date).getTime() - parseDateValue(a.data.date).getTime())
  .slice(0, 4);

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => parseDateValue(b.data.date).getTime() - parseDateValue(a.data.date).getTime())
  .slice(0, 2);

const resumeHref = `${import.meta.env.BASE_URL}resume.pdf`;
const scholarHref = "https://scholar.google.com/citations?user=srZXFMcAAAAJ&hl=en";
const githubHref = "https://github.com/nmotlagh";
const linkedInHref = "https://www.linkedin.com/in/nicholas-kashani-motlagh";
const emailHref = "mailto:kashanimotlagh.1@osu.edu";
const siteOrigin = Astro.site?.href ?? "https://nmotlagh.github.io";
const headshotUrl = Astro.site ? new URL(headshot.src, Astro.site).href : headshot.src;

const stats = [
  { label: "Peer-reviewed", value: `${peerReviewedPublications.length} papers` },
  { label: "QA examples", value: "25K+" },
  { label: "Award", value: "ISVC Best Paper" },
  { label: "Job market", value: "Aug 2026" },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Nick Kashani Motlagh",
  url: siteOrigin,
  jobTitle: "PhD Candidate",
  affiliation: {
    "@type": "CollegeOrUniversity",
    name: "The Ohio State University",
  },
  email: emailHref,
  image: headshotUrl,
  sameAs: [githubHref, linkedInHref, scholarHref],
  knowsAbout: [
    "Machine Learning",
    "Large Language Models",
    "Transformers",
    "Retrieval-Augmented Generation",
    "Selective Prediction",
    "Uncertainty Quantification",
    "LLM Calibration",
    "Evaluation",
    "Distributed Training",
    "PyTorch",
    "Python",
    "Multimodal Systems",
    "Adaptive QA",
  ],
};

const publicationSchemas = peerReviewedPublications.map((pub) => {
  const isBasedOn = [pub.data.code, pub.data.data].filter(Boolean).map((url) => ({
    "@type": "CreativeWork",
    url,
  }));

  return {
    "@context": "https://schema.org",
    "@type": "ScholarlyArticle",
    name: pub.data.title,
    url: `${siteOrigin}publications/${pub.slug}/`,
    datePublished: pub.data.datePublished ?? String(pub.data.year),
    publisher: pub.data.venue
      ? {
          "@type": "Organization",
          name: pub.data.venue,
        }
      : undefined,
    author: pub.data.authors.map((author) => ({
      "@type": "Person",
      name: author,
    })),
    isBasedOn: isBasedOn.length > 0 ? isBasedOn : undefined,
  };
});

const structuredData = [personSchema, ...publicationSchemas];
---

<BaseLayout
  title="Home"
  description="Nick Kashani Motlagh — PhD candidate at Ohio State working on selective prediction, calibration, abstention, and adaptive LLM question answering."
  structuredData={structuredData}
>
  <section class="section section--hero">
    <div class="site-shell">
      <EditorialHero
        eyebrow={homeEditorial.hero.eyebrow}
        availability={homeEditorial.hero.availability}
        title={homeEditorial.hero.title}
        ledeHtml="I build models that know <em>when not to answer.</em>"
        supporting={homeEditorial.hero.supporting}
        status={homeEditorial.hero.status}
        actions={[
          { label: "Resume (PDF)", href: resumeHref, external: true },
          { label: "Email me", href: emailHref, variant: "ghost" },
        ]}
        stats={stats}
        scholarHref={scholarHref}
        githubHref={githubHref}
        linkedInHref={linkedInHref}
        emailHref={emailHref}
      />
    </div>
  </section>

  <section class="section" id="dissertation">
    <div class="site-shell">
      <DissertationPillars
        eyebrow={homeEditorial.dissertation.eyebrow}
        title={homeEditorial.dissertation.title}
        subtitle={homeEditorial.dissertation.subtitle}
        summary={homeEditorial.dissertation.summary}
        pillars={dissertationPillars}
      />
    </div>
  </section>

  <section class="section section--current" id="current-work">
    <div class="site-shell">
      <article class="current-work surface surface--raised">
        <p class="eyebrow">{homeEditorial.currentWork.eyebrow}</p>
        <h2 class="current-work__title">{homeEditorial.currentWork.title}</h2>
        <p class="current-work__body">{homeEditorial.currentWork.body}</p>
        <p class="current-work__disclaimer">{homeEditorial.currentWork.disclaimer}</p>
        <p class="current-work__venue">{homeEditorial.currentWork.venue}</p>
        <div class="current-work__actions">
          <a class="button" href={`${import.meta.env.BASE_URL}publications/adaptive-qa-abstention/`}>
            Manuscript note
          </a>
          <a class="button button--ghost" href="#publications">
            Related papers
          </a>
        </div>
      </article>
    </div>
  </section>

  <section class="section" id="news">
    <div class="site-shell">
      <DispatchList newsItems={newsItems} posts={posts} />
    </div>
  </section>

  <section class="section" id="projects">
    <div class="site-shell stack">
      <SectionHeading
        eyebrow="Built"
        title="Code and data."
        description="Training code, evaluation harnesses, calibration utilities, and datasets tied to the papers."
      />

      <div class="home-artifact-grid">
        {featuredArtifacts.map((artifact) => (
          <article class="home-artifact-card surface">
            <p class="eyebrow">Repo</p>
            <h3>
              <a href={artifact.data.repo} target="_blank" rel="noopener noreferrer">
                {artifact.data.name}
              </a>
            </h3>
            <p>{artifact.data.summary}</p>
            {artifact.data.stack && artifact.data.stack.length > 0 && (
              <ul class="home-artifact-card__stack">
                {artifact.data.stack.map((tech) => (
                  <li>{tech}</li>
                ))}
              </ul>
            )}
            <ul>
              {artifact.data.reproduce.slice(0, 3).map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <div>
        <a class="button button--ghost" href={`${import.meta.env.BASE_URL}artifacts/`}>
          All code and data
        </a>
      </div>
    </div>
  </section>

  <section class="section" id="publications">
    <div class="site-shell stack">
      <SectionHeading
        eyebrow="Selected work"
        title="Papers and reports."
        description="Peer-reviewed papers, public code and data, and current manuscript notes with careful status labels."
      />

      <div class="stack" style="gap: 1.15rem;">
        {featuredPublications.map((entry, index) => (
          <FeatureSlab
            entry={entry}
            artifacts={artifactMap.get(entry.slug)}
            reverse={index % 2 === 1}
          />
        ))}
      </div>

      <div>
        <a class="button button--ghost" href={`${import.meta.env.BASE_URL}publications/`}>
          All publications
        </a>
      </div>
    </div>
  </section>

  <section class="section" id="experience">
    <div class="site-shell stack">
      <SectionHeading
        eyebrow="Experience"
        title="Roles."
        description="Research, teaching, internships, and applied evaluation work."
      />

      <div class="home-experience-grid">
        {experienceItems.slice(0, 4).map((item) => (
          <article class="home-experience-card surface">
            <p class="eyebrow">Role</p>
            <h3>{item.role}</h3>
            <p class="home-experience-card__meta">
              {item.location ? `${item.location} / ${item.timeframe}` : item.timeframe}
            </p>
            {item.bullets && item.bullets.length > 0 && (
              <ul>
                {item.bullets.slice(0, 2).map((bullet) => (
                  <li set:html={bullet} />
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="about">
    <div class="site-shell stack">
      <SectionHeading
        eyebrow="About"
        title="How the research has developed."
        description="From selective prediction in vision to adaptive question answering with LLMs, with stops along the way in multimodal translation and remote sensing."
      />

      <div class="home-about">
        <article class="surface" style="padding: clamp(1.3rem, 3vw, 2.2rem);">
          <div class="prose">
            {aboutRendered && <aboutRendered.Content />}
          </div>
        </article>

        <ResearchArc items={researchArc} />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="site-shell">
      <ContactRail
        facts={homeEditorial.recruiterFacts}
        roles={experienceItems.slice(0, 4).map((item) => ({
          role: item.role,
          location: item.location,
          timeframe: item.timeframe,
        }))}
        resumeHref={resumeHref}
        emailHref={emailHref}
        linkedInHref={linkedInHref}
        githubHref={githubHref}
        scholarHref={scholarHref}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .section--current {
    padding-top: clamp(0.85rem, 2vw, 1.35rem);
  }

  .current-work {
    position: relative;
    display: grid;
    gap: 1.15rem;
    padding: clamp(1.35rem, 3.5vw, 2.8rem);
    overflow: hidden;
    isolation: isolate;
  }

  .current-work::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: radial-gradient(
      color-mix(in srgb, var(--color-text-soft) 26%, transparent) 1px,
      transparent 1px
    );
    background-size: 1.6rem 1.6rem;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.55), transparent 62%);
    -webkit-mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.55), transparent 62%);
  }

  .current-work::after {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--color-positive);
  }

  @media (min-width: 920px) {
    .current-work {
      grid-template-columns: minmax(0, 1fr) minmax(16rem, 0.38fr);
      align-items: end;
    }

    .current-work > .eyebrow,
    .current-work__title,
    .current-work__body,
    .current-work__disclaimer {
      grid-column: 1;
    }

    .current-work__actions,
    .current-work__venue {
      grid-column: 2;
    }
  }

  .current-work__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.25rem + 2.1vw, 3.65rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 0.95;
    max-width: 42rem;
  }

  .current-work__body {
    margin: 0;
    max-width: 55rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.72;
    overflow-wrap: break-word;
  }

  .current-work__disclaimer {
    margin: 0;
    padding: 0.8rem 1rem;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 34%, var(--color-border));
    border-left: 3px solid var(--color-secondary);
    background: color-mix(in srgb, var(--color-secondary-soft) 52%, var(--color-panel) 48%);
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
    border-radius: var(--radius-md);
    overflow-wrap: break-word;
  }

  .current-work__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 0;
  }

  .current-work__venue {
    margin: 0;
    align-self: end;
    color: var(--color-text);
    font: 600 0.8rem/1.2 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    overflow-wrap: break-word;
  }

  @media (max-width: 640px) {
    .current-work {
      width: calc(100vw - 2rem);
      inline-size: calc(100vw - 2rem);
      max-width: calc(100vw - 2rem);
      padding: 1.15rem;
    }

    .current-work__title {
      max-width: 100%;
      font-size: clamp(1.85rem, 7.5vw, 2.2rem);
      overflow-wrap: normal;
    }

    .current-work__body,
    .current-work__disclaimer,
    .current-work__venue {
      inline-size: 100%;
      max-width: 100%;
      min-width: 0;
    }

    .current-work__venue {
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      line-height: 1.35;
    }
  }
</style>

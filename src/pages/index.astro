---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import EditorialHero from "../components/editorial/EditorialHero.astro";
import FeatureSlab from "../components/editorial/FeatureSlab.astro";
import ResearchArc from "../components/editorial/ResearchArc.astro";
import DispatchList from "../components/editorial/DispatchList.astro";
import ContactRail from "../components/editorial/ContactRail.astro";
import { homeEditorial, researchArc } from "../data/editorial";
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";
import headshot from "../assets/headshot.jpg";

const about = await getEntry("pages", "about");
const experience = await getEntry("pages", "experience");
const aboutRendered = about ? await about.render() : undefined;
const experienceItems = experience?.data.items ?? [];

const publicationEntries = await getCollection("publications");
const publications = publicationEntries.sort((a, b) => b.data.year - a.data.year);
const publicationLookup = new Map(publications.map((entry) => [entry.slug, entry]));

const artifactEntries = await getCollection("artifacts");
const artifactMap = new Map<string, CollectionEntry<"artifacts">[]>();
artifactEntries.forEach((artifact) => {
  artifact.data.tiesTo.forEach((slug) => {
    if (!artifactMap.has(slug)) {
      artifactMap.set(slug, []);
    }
    artifactMap.get(slug)?.push(artifact);
  });
});
const artifactLookup = new Map(artifactEntries.map((entry) => [entry.id, entry]));

const featuredPublications = homeEditorial.featuredPublicationSlugs
  .map((slug) => publicationLookup.get(slug))
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));

const featuredArtifacts = homeEditorial.featuredArtifactIds
  .map((id) => artifactLookup.get(id))
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));

const newsItems = (await getCollection("news"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);

const resumeHref = `${import.meta.env.BASE_URL}resume.pdf`;
const scholarHref = "https://scholar.google.com/citations?user=srZXFMcAAAAJ&hl=en";
const githubHref = "https://github.com/nmotlagh";
const linkedInHref = "https://www.linkedin.com/in/nicholas-kashani-motlagh";
const emailHref = "mailto:kashanimotlagh.1@osu.edu";
const siteOrigin = Astro.site?.href ?? "https://nmotlagh.github.io";
const headshotUrl = Astro.site ? new URL(headshot.src, Astro.site).href : headshot.src;

const stats = [
  { label: "First-author pubs", value: `${publications.length}/${publications.length}` },
  { label: "Best Paper", value: "ISVC 2022" },
  { label: "Graduating", value: "Aug 2026" },
  { label: "Available", value: "Fall 2026" },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Nick Kashani Motlagh",
  url: siteOrigin,
  jobTitle: "PhD Candidate",
  affiliation: {
    "@type": "CollegeOrUniversity",
    name: "The Ohio State University",
  },
  email: emailHref,
  image: headshotUrl,
  sameAs: [githubHref, linkedInHref, scholarHref],
  knowsAbout: [
    "Machine Learning",
    "Large Language Models",
    "Transformers",
    "Retrieval-Augmented Generation",
    "Selective Prediction",
    "Uncertainty Quantification",
    "LLM Calibration",
    "Evaluation",
    "Distributed Training",
    "PyTorch",
    "Python",
    "Multimodal Systems",
    "Adaptive QA",
  ],
};

const publicationSchemas = publications.map((pub) => {
  const isBasedOn = [pub.data.code, pub.data.data].filter(Boolean).map((url) => ({
    "@type": "CreativeWork",
    url,
  }));

  return {
    "@context": "https://schema.org",
    "@type": "ScholarlyArticle",
    name: pub.data.title,
    url: `${siteOrigin}publications/${pub.slug}/`,
    datePublished: pub.data.datePublished ?? String(pub.data.year),
    publisher: pub.data.venue
      ? {
          "@type": "Organization",
          name: pub.data.venue,
        }
      : undefined,
    author: pub.data.authors.map((author) => ({
      "@type": "Person",
      name: author,
    })),
    isBasedOn: isBasedOn.length > 0 ? isBasedOn : undefined,
  };
});

const structuredData = [personSchema, ...publicationSchemas];
const current = homeEditorial.currentWork;
---

<BaseLayout
  title="Home"
  description="Nick Kashani Motlagh — PhD candidate at Ohio State working on selective prediction, abstention, and adaptive question answering with LLMs."
  structuredData={structuredData}
>
  <section class="section">
    <div class="site-shell">
      <EditorialHero
        eyebrow={homeEditorial.hero.eyebrow}
        title={homeEditorial.hero.title}
        lede={homeEditorial.hero.lede}
        supporting={homeEditorial.hero.supporting}
        status={homeEditorial.hero.status}
        actions={[
          { label: "Resume (PDF)", href: resumeHref, external: true },
          { label: "Email me", href: emailHref, variant: "ghost" },
        ]}
        stats={stats}
        scholarHref={scholarHref}
        githubHref={githubHref}
        linkedInHref={linkedInHref}
        emailHref={emailHref}
      />
    </div>
  </section>

  <section class="section" id="current">
    <div class="site-shell">
      <article class="current-work surface">
        <p class="eyebrow">{current.eyebrow}</p>
        <h2 class="current-work__title">{current.title}</h2>
        <p class="current-work__body">{current.body}</p>
        <p class="current-work__venue">{current.venue}</p>
      </article>
    </div>
  </section>

  <section class="section" id="news">
    <div class="site-shell">
      <DispatchList newsItems={newsItems} posts={posts} />
    </div>
  </section>

  <section class="section" id="projects">
    <div class="site-shell stack">
      <SectionHeading
        eyebrow="Built"
        title="Projects and open-source."
        description="Training code, evaluation harnesses, and datasets I wrote and ship under my GitHub."
      />

      <div class="home-artifact-grid">
        {featuredArtifacts.map((artifact) => (
          <article class="home-artifact-card surface">
            <p class="eyebrow">Repo</p>
            <h3>
              <a href={artifact.data.repo} target="_blank" rel="noopener noreferrer">
                {artifact.data.name}
              </a>
            </h3>
            <p>{artifact.data.summary}</p>
            {artifact.data.stack && artifact.data.stack.length > 0 && (
              <ul class="home-artifact-card__stack">
                {artifact.data.stack.map((tech) => (
                  <li>{tech}</li>
                ))}
              </ul>
            )}
            <ul>
              {artifact.data.reproduce.slice(0, 3).map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <div>
        <a class="button button--ghost" href={`${import.meta.env.BASE_URL}artifacts/`}>
          All repos
        </a>
      </div>
    </div>
  </section>

  <section class="section" id="publications">
    <div class="site-shell stack">
      <SectionHeading
        eyebrow="Selected work"
        title="Publications."
        description="Each paper links out to the PDF, code, or data where available."
      />

      <div class="stack" style="gap: 1.15rem;">
        {featuredPublications.map((entry, index) => (
          <FeatureSlab
            entry={entry}
            artifacts={artifactMap.get(entry.slug)}
            reverse={index % 2 === 1}
          />
        ))}
      </div>

      <div>
        <a class="button button--ghost" href={`${import.meta.env.BASE_URL}publications/`}>
          All publications
        </a>
      </div>
    </div>
  </section>

  <section class="section" id="experience">
    <div class="site-shell stack">
      <SectionHeading
        eyebrow="Experience"
        title="Roles."
        description="Research, teaching, and internships."
      />

      <div class="home-experience-grid">
        {experienceItems.slice(0, 4).map((item) => (
          <article class="home-experience-card surface">
            <p class="eyebrow">Role</p>
            <h3>{item.role}</h3>
            <p class="home-experience-card__meta">
              {item.location ? `${item.location} / ${item.timeframe}` : item.timeframe}
            </p>
            {item.bullets && item.bullets.length > 0 && (
              <ul>
                {item.bullets.slice(0, 2).map((bullet) => (
                  <li set:html={bullet} />
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="about">
    <div class="site-shell stack">
      <SectionHeading
        eyebrow="About"
        title="How the research has developed."
        description="From selective prediction in vision to adaptive question answering with LLMs, with stops along the way in multimodal translation and remote sensing."
      />

      <div class="home-about">
        <article class="surface" style="padding: clamp(1.3rem, 3vw, 2.2rem);">
          <div class="prose">
            {aboutRendered && <aboutRendered.Content />}
          </div>
        </article>

        <ResearchArc items={researchArc} />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="site-shell">
      <ContactRail
        facts={homeEditorial.recruiterFacts}
        roles={experienceItems.slice(0, 4).map((item) => ({
          role: item.role,
          location: item.location,
          timeframe: item.timeframe,
        }))}
        resumeHref={resumeHref}
        emailHref={emailHref}
        linkedInHref={linkedInHref}
        githubHref={githubHref}
        scholarHref={scholarHref}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .current-work {
    padding: clamp(1.5rem, 3.5vw, 2.6rem);
  }

  .current-work__title {
    margin: 0.6rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 1.2rem + 1.6vw, 2.6rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    max-width: 54rem;
    text-wrap: balance;
  }

  .current-work__body {
    margin: 1.1rem 0 0;
    max-width: 52rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .current-work__venue {
    margin: 1.2rem 0 0;
    color: var(--color-text-soft);
    font: 600 0.8rem/1.2 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .home-artifact-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.9rem 0 0.3rem;
    padding: 0;
    list-style: none;
  }

  .home-artifact-card__stack li {
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    font: 500 0.72rem/1.2 var(--font-mono);
    letter-spacing: 0.04em;
  }
</style>

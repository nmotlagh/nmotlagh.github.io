---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/dates';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const rendered = await post.render();
const dateFormat = { month: 'long', day: 'numeric', year: 'numeric' } satisfies Intl.DateTimeFormatOptions;

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  author: {
    '@type': 'Person',
    name: 'Nick Kashani Motlagh',
  },
  url: Astro.site ? new URL(`blog/${post.slug}/`, Astro.site).href : undefined,
};
---

<BaseLayout title={post.data.title} description={post.data.description} structuredData={blogPostSchema}>
  <section class="section">
    <article class="site-shell detail-page">
      <a class="detail-backlink" href={`${import.meta.env.BASE_URL}blog/`}>
        ← Back to blog
      </a>

      <header class="detail-page__hero surface surface--raised">
        <div>
          <p class="eyebrow">Notebook entry</p>
          <h1 data-pretext-balance data-pretext-source={post.data.title}>{post.data.title}</h1>
          <p class="detail-page__byline">{formatDate(post.data.date, dateFormat)}</p>
        </div>

        <div class="detail-page__aside">
          <aside class="detail-note surface">
            <p class="eyebrow">Summary</p>
            <p style="margin: 0;">{post.data.description}</p>
          </aside>

          {post.data.tags.length > 0 && (
            <div class="detail-note surface">
              <p class="eyebrow">Tags</p>
              <ul class="tag-list">
                {post.data.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </header>

      <section class="surface" style="padding: clamp(1.3rem, 3vw, 2.2rem);">
        <div class="prose">
          <rendered.Content />
        </div>
      </section>
    </article>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
const formatter = new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<BaseLayout title="Blog" description="Writing on selective prediction, uncertainty quantification, and adaptive question answering.">
  <section class="section">
    <div class="site-shell archive-page">
      <div class="archive-page__header">
        <div>
          <SectionHeading
            eyebrow="Writing"
            title="Blog"
            description="Longer-form notes on selective prediction, uncertainty quantification, evaluation design, and the gap between what models know and what they claim to know."
          />
        </div>

        <p class="archive-page__aside">
          The blog is the slower companion to the paper archive: fewer entries,
          more argument, and more room for ideas that are not yet finished.
        </p>
      </div>

      {posts.length === 0 ? (
        <p class="archive-page__aside">No posts yet. Check back soon.</p>
      ) : (
        <ol class="blog-index-list">
          {posts.map((post) => (
            <li>
              <time datetime={post.data.date}>{formatter.format(new Date(post.data.date))}</time>
              <a href={`${import.meta.env.BASE_URL}blog/${post.slug}/`}>
                <h3 data-pretext-balance data-pretext-source={post.data.title}>{post.data.title}</h3>
              </a>
              <p>{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <ul class="tag-list">
                  {post.data.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const artifacts = (await getCollection('artifacts')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
const publications = await getCollection('publications', ({ data }) => !data.draft);
const publicationLookup = new Map(publications.map((pub) => [pub.slug, pub.data.title]));
---

<BaseLayout title="Artifacts" description="Pinned GitHub repositories, datasets, and eval harnesses for every publication.">
  <section class="section">
    <div class="site-shell archive-page">
      <div class="archive-page__header">
        <div>
          <SectionHeading
            as="h1"
            eyebrow="Open source"
            title="Artifacts and GitHub repos"
            description="A compact archive of the code, dashboards, and datasets that turn the papers into something runnable."
          />
        </div>

        <p class="archive-page__aside">
          Each entry links the repository to the corresponding paper and lists
          the main reproducibility path: scripts, reports, datasets, or
          evaluation outputs.
        </p>
      </div>

      <div class="grid grid--2 archive-page__grid">
        {artifacts.map((artifact) => {
          const tiedPublications = artifact.data.tiesTo
            .map((slug) => ({ slug, title: publicationLookup.get(slug) }))
            .filter((item): item is { slug: string; title: string } => Boolean(item.title));
          return (
            <article class="artifact-archive-card surface">
              <div class="artifact-card__header">
                <h3>
                  <a href={artifact.data.repo} target="_blank" rel="noopener noreferrer">
                    {artifact.data.name}
                  </a>
                </h3>
                <a
                  class="badge badge--link"
                  href={artifact.data.repo}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`GitHub repository for ${artifact.data.name}`}
                >
                  GitHub
                </a>
              </div>
              <p>{artifact.data.summary}</p>
              <ul>
                {artifact.data.reproduce.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              {tiedPublications.length > 0 && (
                <p class="artifact-card__ties">
                  Supports:&nbsp;
                  {tiedPublications.map((item, index) => (
                    <span>
                      <a href={`${import.meta.env.BASE_URL}publications/${item.slug}/`}>{item.title}</a>
                      {index < tiedPublications.length - 1 ? ', ' : ''}
                    </span>
                  ))}
                </p>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .artifact-archive-card {
    padding: 1.2rem;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .artifact-archive-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .artifact-card__header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 1rem;
  }

  .artifact-card__header h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 650;
    line-height: 1.08;
  }

  .artifact-card__header h3 a {
    color: inherit;
    text-decoration: none;
  }

  .artifact-card__header h3 a:hover,
  .artifact-card__header h3 a:focus-visible {
    color: var(--color-accent);
  }

  .artifact-archive-card p {
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .artifact-archive-card ul {
    margin: 0;
    padding-left: 1.05rem;
    color: var(--color-text-muted);
    display: grid;
    gap: 0.55rem;
  }

  .artifact-archive-card li::marker {
    color: var(--color-accent);
  }

  .artifact-card__ties {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .artifact-card__header {
      display: grid;
    }
  }
</style>

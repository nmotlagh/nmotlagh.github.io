---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const newsItems = (await getCollection('news')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
const formatter = new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<BaseLayout title="News" description="Latest publications, releases, and results across selective prediction and multimodal ML.">
  <section class="section">
    <div class="site-shell archive-page">
      <div class="archive-page__header">
        <div>
          <SectionHeading
            eyebrow="Updates"
            title="News and announcements"
            description="A quick-running log of publications, submissions, releases, and career updates."
          />
        </div>

        <p class="archive-page__aside">
          This is the fastest page to scan if you only want to know what changed
          recently. The full archive is also available via RSS.
        </p>
      </div>

      <ol class="news-timeline">
        {newsItems.map((item) => (
          <li>
            <time datetime={item.data.date}>{formatter.format(new Date(item.data.date))}</time>
            {item.data.link ? (
              <a href={item.data.link} target="_blank" rel="noopener noreferrer">
                {item.data.title}
              </a>
            ) : (
              <span>{item.data.title}</span>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>
</BaseLayout>
